{
  "name": "slavey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build",
    "build:web": "tsc --noEmit && vite build",
    "check": "npm run check:web && npm run check:rust",
    "check:web": "npm run typecheck && npm run test:web:run && vite build && npm run check:bundle",
    "check:rust": "npm run check:format && npm run check:clippy && npm run test:rust",
    "check:format": "cd src-tauri && cargo fmt -- --check",
    "check:clippy": "cd src-tauri && cargo clippy --all-targets -- -D warnings",
    "test:rust": "cd src-tauri && cargo test",
    "test:web": "vitest",
    "test:web:run": "vitest run",
    "test:e2e": "playwright test --ui",
    "test:e2e:run": "playwright test",
    "check:e2e": "npm run test:e2e:run",
    "check:bundle": "node scripts/check-production-bundle.mjs",
    "check:frontend-tests": "npm run test:web:run",
    "typecheck": "tsc --noEmit",
    "install-hooks": "git config core.hooksPath .githooks",
    "preview": "vite preview --host 127.0.0.1 --port 1420"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
